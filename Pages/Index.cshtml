@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<h1 class="text-center">My posts</h1>

<div class="row">
    <div class="col-md-2 d-flex flex-column gap-3">
        <a asp-page="/Posts/Create" class="btn btn-primary btn-sm">New Post</a>
        <a asp-page="/Authors/Create" class="btn btn-primary btn-sm">New Author</a>
        <a asp-page="/Categories/Create" class="btn btn-primary btn-sm">New Category</a>
    </div>

    <div class="col-md-7">
        @foreach(var post in Model.Posts){
            <div class="card mb-3">
                <div class="card-body">
                    <h6 class="card-title">@post.Title</h6>
                    <span class="text-sm text-muted">by @post.Author.Name</span>
                    <span class="text-muted">in
                        <a asp-page="/Categories/Details" asp-route-id=@post.Category.Id>@post.Category.Name</a>
                    </span>
                    <p class="card-text mt-3">@post.Excerpt</p>

                    <a asp-page="/Posts/Details" asp-route-id="@post.Id">Read more</a>
                </div>
            
            </div>
        }
    </div>
    <div class="col-md-3">
        <h3>Categories</h3>
        @foreach(var category in Model.Categories){
        <div class="mb-4">
            <h6 class="fw-bold">@category.Name</h6>
            <ul>
                @foreach(var post in category.Posts)
                {
                    <li>
                        <a asp-page="/Posts/Details" asp-route-id="@post.Id">
                            @post.Title
                        </a>
                    </li>
                }
            </ul>
        </div>
    }
    </div>

    
</div>